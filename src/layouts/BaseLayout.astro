---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Philip Abakah — Optometrist & AI Engineer | Vision Science',
  description =
    'Building assistive intelligence for human vision. Vision Scientist, Optometrist, and AI Developer working at the intersection of machine learning and eye care.',
  image = '/images/profile.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Author & crawl signals -->
    <meta name="author" content="Philip Abakah" />
    <meta name="robots" content="index, follow" />
    <meta property="og:site_name" content="Philip Abakah" />
    <meta property="og:locale" content="en_US" />

    <!-- JSON-LD Person Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Philip Abakah",
      "alternateName": ["Philip Abakah Mensah", "OD Philip Abakah"],
      "url": "https://philipabakah.com",
      "image": "https://philipabakah.com/images/profile.jpg",
      "jobTitle": ["Optometrist", "AI Engineer", "Vision Scientist"],
      "description": "Vision Scientist Engineer and Optometrist building AI systems at the intersection of machine learning and eye care. Creator of Safe Step and EyeDxAI.",
      "email": "philipabakahmensah@gmail.com",
      "sameAs": [
        "https://github.com/Strange-Philip",
        "https://www.linkedin.com/in/philip-abakah-od-22a45a206/"
      ],
      "knowsAbout": ["Computer Vision", "Machine Learning", "Optometry", "YOLOv8", "Flutter", "AI Healthcare"],
      "nationality": "Ghanaian",
      "address": { "@type": "PostalAddress", "addressLocality": "Accra", "addressCountry": "GH" }
    }
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#09090b" />

    <!-- Fonts — non-blocking preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Caveat:wght@500;700&display=swap"
    />
    <link
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Caveat:wght@500;700&display=swap"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Caveat:wght@500;700&display=swap"
      />
    </noscript>

    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Hidden SVG color blindness filter definitions -->
    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter id="cvd-deuteranopia">
          <feColorMatrix type="matrix" values="
            0.367  0.861 -0.228  0  0
            0.280  0.673  0.047  0  0
           -0.012  0.043  0.969  0  0
            0      0      0      1  0"/>
        </filter>
        <filter id="cvd-protanopia">
          <feColorMatrix type="matrix" values="
            0.152  1.053 -0.205  0  0
            0.115  0.786  0.099  0  0
           -0.004 -0.048  1.052  0  0
            0      0      0      1  0"/>
        </filter>
        <filter id="cvd-tritanopia">
          <feColorMatrix type="matrix" values="
            1.256 -0.077 -0.180  0  0
           -0.078  0.931  0.148  0  0
            0.005  0.691  0.304  0  0
            0      0      0      1  0"/>
        </filter>
      </defs>
    </svg>

    <!-- Toast -->
    <style>
      #cvd-toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9000;
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 10px 16px;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--color-text-secondary);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease, transform 0.25s ease;
        transform: translateY(0);
      }
      @media (max-width: 768px) {
        #cvd-toast {
          right: auto;
          left: 50%;
          transform: translateX(-50%) translateY(16px);
          width: calc(100vw - 48px);
          max-width: 340px;
          text-align: center;
          border-radius: 12px;
        }
        #cvd-toast.toast-visible {
          transform: translateX(-50%) translateY(0);
        }
      }
    </style>
    <div id="cvd-toast" aria-live="polite"></div>

    <!-- Latency HUD -->
    <div id="latency-hud" style="
      display:none; position:fixed; top:16px; right:16px; z-index:8900;
      background:rgba(9,9,11,0.92); border:1px solid #34d399;
      border-radius:8px; padding:14px 18px; font-family:var(--font-mono);
      font-size:11px; color:#34d399; line-height:1.9;
      backdrop-filter:blur(8px); min-width:200px;
    " aria-live="polite">
      <div style="font-size:9px;letter-spacing:0.12em;color:#71717a;margin-bottom:6px;text-transform:uppercase;">◈ Latency HUD — Shift+L to close</div>
      <div>FPS &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: <span id="hud-fps">--</span></div>
      <div>Inference : <span id="hud-latency">--</span> ms</div>
      <div>Confidence: <span id="hud-conf">--</span></div>
      <div>Memory &nbsp;&nbsp;: <span id="hud-mem">--</span></div>
      <div style="margin-top:6px;padding-top:6px;border-top:1px solid #27272a;font-size:9px;color:#52525b;">YOLOv8n · on-device · Ghana</div>
    </div>

    <!-- Blind Spot Demo modal -->
    <div id="blindspot-modal" style="
      display:none; position:fixed; inset:0; z-index:9998;
      background:rgba(0,0,0,0.96); align-items:center; justify-content:center; flex-direction:column;
    " role="dialog" aria-modal="true" aria-label="Blind Spot Demonstration">
      <p style="font-family:monospace;font-size:11px;color:#52525b;letter-spacing:0.1em;margin-bottom:32px;text-transform:uppercase;">Blind Spot Demonstration</p>
      <div style="display:flex;align-items:center;gap:120px;margin-bottom:40px;">
        <div style="width:22px;height:22px;position:relative;">
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
            <div style="width:2px;height:22px;background:#f4f4f5;"></div>
          </div>
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
            <div style="height:2px;width:22px;background:#f4f4f5;"></div>
          </div>
        </div>
        <div id="bs-dot" style="width:18px;height:18px;background:#34d399;border-radius:50%;"></div>
      </div>
      <div style="max-width:400px;text-align:center;">
        <p style="font-family:monospace;font-size:13px;color:#a1a1aa;line-height:1.8;margin-bottom:10px;">
          Cover your <strong style="color:#f4f4f5;">right eye</strong>. Focus on the <strong style="color:#f4f4f5;">cross</strong> with your left.<br/>
          Slowly move back from the screen.<br/>
          The green dot will <strong style="color:#34d399;">disappear</strong>.
        </p>
        <p style="font-family:monospace;font-size:11px;color:#52525b;line-height:1.7;">
          That's your optic disc — where the nerve exits, there are no photoreceptors.<br/>
          Your brain fills it in. Models learn to do the same.
        </p>
      </div>
      <button onclick="document.getElementById('blindspot-modal').style.display='none'" style="
        margin-top:32px;font-size:11px;color:#52525b;background:none;border:none;cursor:pointer;font-family:monospace;
      ">[ press Esc or B to close ]</button>
    </div>

    <!-- Foveated rendering overlay -->
    <div id="foveal-overlay" style="
      display:none; position:fixed; inset:0; z-index:8800;
      pointer-events:none;
      background:radial-gradient(circle at var(--fx,50%) var(--fy,50%), transparent 0px, transparent 110px, rgba(9,9,11,0.45) 260px, rgba(9,9,11,0.82) 480px);
    " aria-hidden="true"></div>

    <!-- Konami / Snellen modal -->
    <div id="snellen-modal" style="
      display:none; position:fixed; inset:0; z-index:9999;
      background:rgba(0,0,0,0.92); align-items:center; justify-content:center;
    " role="dialog" aria-modal="true" aria-label="Snellen Eye Chart">
      <div style="
        background:#fafafa; color:#111; border-radius:16px;
        padding:40px 48px; max-width:380px; width:90%;
        text-align:center; position:relative;
        box-shadow:0 32px 80px rgba(0,0,0,0.6);
      ">
        <p style="font-size:10px;font-family:monospace;letter-spacing:0.15em;color:#888;margin-bottom:20px;text-transform:uppercase;">Visual Acuity Test</p>
        <div style="font-family:'Courier New',monospace;line-height:2.2;font-weight:700;">
          <div style="font-size:42px;">E</div>
          <div style="font-size:30px;">F P</div>
          <div style="font-size:22px;">T O Z</div>
          <div style="font-size:17px;">L P E D</div>
          <div style="font-size:13px;">P E C F D</div>
          <div style="font-size:11px;">E D F C Z P</div>
          <div style="font-size:9px;">F E L O P Z D</div>
          <div style="font-size:8px;color:#34d399;font-family:'Geist Mono',monospace;letter-spacing:-0.02em;margin-top:4px;">
            If you can read this, your vision is perfect.<br/>Mine runs at 30fps.
          </div>
        </div>
        <p style="font-family:monospace;font-size:9px;color:#aaa;margin-top:18px;letter-spacing:0.08em;">
          Visual acuity: 20/20 &middot; OD Philip Abakah
        </p>
        <button onclick="document.getElementById('snellen-modal').style.display='none'" style="
          margin-top:20px;font-size:11px;color:#888;background:none;border:none;cursor:pointer;font-family:monospace;
        ">[ press Esc or click outside to dismiss ]</button>
      </div>
    </div>

    <slot />
    <script>import { inject } from '@vercel/analytics'; inject();</script>

    <script is:inline>
      // ── Easter Egg 1: Console message ──────────────────────────────
      console.log(
        '%c 👁  %c Philip Abakah %c\n\n' +
        '%c You found the console. Impressive.\n' +
        ' So did my YOLOv8 model — it just called you\n' +
        ' a "person" with 94.2% confidence.\n\n' +
        '%c  philipabakahmensah@gmail.com\n' +
        '  github.com/Strange-Philip\n',
        'font-size:32px;line-height:1.4',
        'font-size:18px;font-weight:700;color:#34d399',
        'font-size:14px',
        'font-size:13px;color:#a1a1aa;line-height:1.8',
        'font-size:12px;font-family:monospace;color:#71717a'
      );

      // ── Easter Egg 2: Color blindness simulator (Shift+V) ──────────
      var isMobile = 'ontouchstart' in window;
      var cvdHint = isMobile ? 'long press blank area to cycle' : 'Shift+V to cycle';
      const cvdModes = [
        { label: 'Normal vision', filter: '' },
        { label: '👁 Deuteranopia (red-green) — ' + cvdHint, filter: 'url(#cvd-deuteranopia)' },
        { label: '👁 Protanopia (red) — ' + cvdHint, filter: 'url(#cvd-protanopia)' },
        { label: '👁 Tritanopia (blue-yellow) — ' + cvdHint, filter: 'url(#cvd-tritanopia)' },
      ];
      let cvdIndex = parseInt(localStorage.getItem('cvd-index') || '0', 10);
      const toast = document.getElementById('cvd-toast');
      let toastTimer = 0;

      // Restore filter on every page load
      if (cvdIndex > 0) {
        document.documentElement.style.filter = cvdModes[cvdIndex].filter;
      }

      function showToast(msg) {
        if (!toast) return;
        toast.textContent = msg;
        toast.style.opacity = '1';
        toast.classList.add('toast-visible');
        clearTimeout(toastTimer);
        toastTimer = window.setTimeout(() => {
          toast.style.opacity = '0';
          toast.classList.remove('toast-visible');
        }, 2800);
      }

      document.addEventListener('keydown', (e) => {
        if (e.shiftKey && e.key === 'V') {
          cvdIndex = (cvdIndex + 1) % cvdModes.length;
          const mode = cvdModes[cvdIndex];
          document.documentElement.style.filter = mode.filter;
          localStorage.setItem('cvd-index', String(cvdIndex));
          showToast(mode.label);
        }
      });

      // ── Mobile: long press on blank space (700ms) → CVD filter ───
      var TEXT_TAGS = /^(A|BUTTON|IMG|INPUT|TEXTAREA|SELECT|VIDEO|AUDIO|LABEL|NAV|P|H1|H2|H3|H4|H5|H6|LI|SPAN|STRONG|EM|B|I|U|CODE|PRE|SMALL|FIGCAPTION|BLOCKQUOTE|SVG|PATH|CIRCLE|RECT|TIME)$/;
      let longPressTimer = 0;
      document.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) return;
        var t = e.target;
        if (TEXT_TAGS.test(t.tagName)) return;
        if (t.closest('a') || t.closest('button') || t.closest('nav') || t.closest('img')) return;
        longPressTimer = window.setTimeout(() => {
          cvdIndex = (cvdIndex + 1) % cvdModes.length;
          const mode = cvdModes[cvdIndex];
          document.documentElement.style.filter = mode.filter;
          localStorage.setItem('cvd-index', String(cvdIndex));
          showToast(mode.label);
          if (navigator.vibrate) navigator.vibrate(cvdIndex === 0 ? [80, 40, 80] : 120);
        }, 700);
      }, { passive: true });
      document.addEventListener('touchend',      () => clearTimeout(longPressTimer), { passive: true });
      document.addEventListener('touchmove',     () => clearTimeout(longPressTimer), { passive: true });
      document.addEventListener('touchcancel',   () => clearTimeout(longPressTimer), { passive: true });
      document.addEventListener('selectionchange', () => clearTimeout(longPressTimer));
      document.addEventListener('contextmenu',   () => clearTimeout(longPressTimer));

      // ── Easter Egg 3: Latency HUD (Shift+L) ───────────────────────
      const hud = document.getElementById('latency-hud');
      const hudFps = document.getElementById('hud-fps');
      const hudLat = document.getElementById('hud-latency');
      const hudConf = document.getElementById('hud-conf');
      const hudMem = document.getElementById('hud-mem');
      let hudActive = false;
      let lastFrame = performance.now();
      let frameCount = 0;
      let hudRaf = 0;

      function hudTick() {
        frameCount++;
        const now = performance.now();
        if (now - lastFrame >= 500) {
          const fps = Math.round(frameCount / ((now - lastFrame) / 1000));
          if (hudFps) hudFps.textContent = String(fps);
          if (hudLat) hudLat.textContent = String((16 + Math.random() * 28).toFixed(1));
          if (hudConf) hudConf.textContent = (0.87 + Math.random() * 0.12).toFixed(3);
          const mem = performance.memory;
          if (hudMem) hudMem.textContent = mem ? Math.round(mem.usedJSHeapSize / 1048576) + ' MB' : 'n/a';
          lastFrame = now;
          frameCount = 0;
        }
        if (hudActive) hudRaf = requestAnimationFrame(hudTick);
      }

      document.addEventListener('keydown', (e) => {
        if (e.shiftKey && e.key === 'L') {
          hudActive = !hudActive;
          if (hud) hud.style.display = hudActive ? 'block' : 'none';
          if (hudActive) { lastFrame = performance.now(); frameCount = 0; hudRaf = requestAnimationFrame(hudTick); }
          else cancelAnimationFrame(hudRaf);
        }
      });

      // ── Easter Egg 4: Blind Spot Demo (B key) ─────────────────────
      const bsModal = document.getElementById('blindspot-modal');
      document.addEventListener('keydown', (e) => {
        if (e.key === 'b' && !e.shiftKey && !e.ctrlKey && !e.metaKey) {
          const tag = e.target && e.target.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          if (bsModal) {
            const isOpen = bsModal.style.display === 'flex';
            bsModal.style.display = isOpen ? 'none' : 'flex';
          }
        }
        if (e.key === 'Escape' && bsModal) bsModal.style.display = 'none';
      });
      if (bsModal) {
        bsModal.addEventListener('click', (e) => { if (e.target === bsModal) bsModal.style.display = 'none'; });
      }

      // ── Easter Egg 5: Foveated Rendering (F key toggle) ────────────
      const fovOverlay = document.getElementById('foveal-overlay');
      let fovActive = false;

      document.addEventListener('keydown', (e) => {
        if (e.key === 'f' && !e.shiftKey && !e.ctrlKey && !e.metaKey) {
          const tag = e.target && e.target.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          fovActive = !fovActive;
          if (fovOverlay) fovOverlay.style.display = fovActive ? 'block' : 'none';
          showToast(fovActive ? '👁 Foveated rendering · press F to exit' : 'Foveated rendering off');
        }
      });

      document.addEventListener('mousemove', (e) => {
        if (!fovActive || !fovOverlay) return;
        fovOverlay.style.setProperty('--fx', e.clientX + 'px');
        fovOverlay.style.setProperty('--fy', e.clientY + 'px');
      });

      // ── Easter Egg 6: Papers Mode (P key) ─────────────────────────
      document.addEventListener('keydown', (e) => {
        if (e.key === 'p' && !e.shiftKey && !e.ctrlKey && !e.metaKey) {
          const tag = e.target && e.target.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA') return;
          const active = document.documentElement.hasAttribute('data-papers-mode');
          if (active) {
            document.documentElement.removeAttribute('data-papers-mode');
            showToast('Papers mode off');
          } else {
            document.documentElement.setAttribute('data-papers-mode', '');
            showToast('📄 Papers mode · press P to exit');
          }
        }
      });

      // ── Easter Egg 7: Model View (Shift+M) ────────────────────────
      document.addEventListener('keydown', (e) => {
        if (e.shiftKey && e.key === 'M') {
          const active = document.documentElement.hasAttribute('data-model-view');
          if (active) {
            document.documentElement.removeAttribute('data-model-view');
            showToast('Human vision restored');
          } else {
            document.documentElement.setAttribute('data-model-view', '');
            showToast('🤖 Model view active · Shift+M to exit');
          }
        }
      });

      // ── Easter Egg 8: Konami code → Snellen chart ──────────────────
      const KONAMI = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
      let kIdx = 0;
      const modal = document.getElementById('snellen-modal');

      document.addEventListener('keydown', (e) => {
        if (e.key === KONAMI[kIdx]) {
          kIdx++;
          if (kIdx === KONAMI.length) {
            kIdx = 0;
            if (modal) {
              modal.style.display = 'flex';
              const btn = modal.querySelector('button');
              if (btn) btn.focus();
            }
          }
        } else {
          kIdx = e.key === KONAMI[0] ? 1 : 0;
        }
      });

      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) modal.style.display = 'none';
        });
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal) modal.style.display = 'none';
      });

      // ══════════════════════════════════════════════════════════════
      // ── Mobile Touch Easter Eggs ──────────────────────────────────
      // ══════════════════════════════════════════════════════════════

      // ── Shake → Blind Spot Demo ───────────────────────────────────
      if (window.DeviceMotionEvent) {
        var lastShakeTime = 0;
        window.addEventListener('devicemotion', function(e) {
          var acc = e.accelerationIncludingGravity;
          if (!acc) return;
          var force = Math.abs(acc.x || 0) + Math.abs(acc.y || 0) + Math.abs(acc.z || 0);
          var now = Date.now();
          if (force > 35 && now - lastShakeTime > 1500) {
            lastShakeTime = now;
            if (bsModal) bsModal.style.display = 'flex';
            if (navigator.vibrate) navigator.vibrate([80, 50, 80]);
          }
        }, { passive: true });
      }

      // ── Triple tap profile photo → Model View ─────────────────────
      var photoEl = document.querySelector('.hero-photo-tilt');
      var photoTapCount = 0, photoTapTimer = 0;
      if (photoEl) {
        photoEl.addEventListener('touchend', function(e) {
          if (e.changedTouches.length !== 1) return;
          photoTapCount++;
          clearTimeout(photoTapTimer);
          photoTapTimer = window.setTimeout(function() { photoTapCount = 0; }, 450);
          if (photoTapCount === 3) {
            photoTapCount = 0;
            var active = document.documentElement.hasAttribute('data-model-view');
            if (active) {
              document.documentElement.removeAttribute('data-model-view');
              showToast('Human vision restored');
            } else {
              document.documentElement.setAttribute('data-model-view', '');
              showToast('🤖 Model view active · triple tap photo to exit');
            }
            if (navigator.vibrate) navigator.vibrate(active ? 40 : [50, 30, 100]);
          }
        }, { passive: true });
      }
    </script>
  </body>
</html>
