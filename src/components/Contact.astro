<section id="contact" class="section contact-section" aria-label="Contact">
  <div class="container contact-inner">
    <p class="section-label">✉️ Contact</p>

    <blockquote class="contact-quote">
      I'm not interested in just building models.<br />
      I'm interested in what happens <em>after the model runs.</em>
    </blockquote>

    <h2 class="contact-heading">Let's work together.</h2>

    <p class="contact-sub">
      Open to research collaborations, engineering roles in assistive AI and computer vision,
      and conversations about building accessible systems that actually work in the real world.
    </p>

    <div class="contact-ctas">
      <a href="mailto:philipabakahmensah@gmail.com" class="btn btn-primary btn-magic">
        Say hello! 👋
      </a>
      <a
        href="https://www.linkedin.com/in/philip-abakah"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost"
      >
        LinkedIn →
      </a>
    </div>

    <p class="contact-email">philipabakahmensah@gmail.com</p>

    <p class="contact-footer">
      Crafted with ❤️ by Philip Abakah
    </p>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border-soft);
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
  }

  .contact-quote {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    border-left: 2px solid var(--color-accent);
    padding-left: 18px;
    margin-bottom: 32px;
    text-align: left;
    max-width: 400px;
  }

  .contact-quote em {
    color: var(--color-text);
    font-style: italic;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: 18px;
    line-height: 1.05;
  }

  .contact-sub {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 36px;
    max-width: 440px;
  }

  .contact-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 24px;
  }

  .contact-email {
    font-size: 12px;
    color: var(--color-text-mute);
    margin-bottom: 48px;
  }

  .contact-footer {
    font-size: 13px;
    color: var(--color-text-mute);
  }
</style>
