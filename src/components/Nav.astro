---
import { navLinks } from '../data/nav';
---

<header class="nav-wrap">
  <nav class="nav-pill" aria-label="Main navigation">
    <!-- Logo: PA two-shape mark -->
    <a href="/" class="nav-logo" aria-label="Philip Abakah — home">
      <svg width="48" height="20" viewBox="0 0 86 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="0" y="2" width="18" height="32" rx="5" fill="#6ee7b7"/>
        <circle cx="38" cy="18" r="17" fill="#34d399"/>
        <path d="M72 2 L56 34 L86 34 Z" fill="#059669"/>
      </svg>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link">{link.label}</a>
        </li>
      ))}
    </ul>

    <!-- Right: theme toggle + mobile hamburger -->
    <div class="nav-right">
      <button class="nav-theme-btn" id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <details class="nav-mobile">
        <summary class="nav-hamburger" aria-label="Toggle navigation menu">
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
          <span class="hamburger-bar"></span>
        </summary>
        <div class="nav-mobile-dropdown">
          <ul role="list">
            {navLinks.map((link) => (
              <li>
                <a href={link.href} class="nav-mobile-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;
  if (localStorage.getItem('theme') === 'light') html.setAttribute('data-theme', 'light');
  btn?.addEventListener('click', () => {
    const isLight = html.getAttribute('data-theme') === 'light';
    if (isLight) { html.removeAttribute('data-theme'); localStorage.setItem('theme', 'dark'); }
    else { html.setAttribute('data-theme', 'light'); localStorage.setItem('theme', 'light'); }
  });
</script>

<style>
  /* Not fixed — scrolls with page */
  .nav-wrap {
    display: flex;
    justify-content: center;
    padding: 20px 20px 0;
  }

  .nav-pill {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 720px;
    height: 52px;
    padding: 0 10px 0 14px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    gap: 8px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }
  .nav-logo:hover { opacity: 1; }

  /* Desktop links — centered */
  .nav-links {
    display: none;
    list-style: none;
    gap: 1px;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .nav-links { display: flex; }
    .nav-mobile { display: none; }
  }

  .nav-link {
    font-size: 13px;
    font-weight: 450;
    color: var(--color-text-tertiary);
    text-decoration: none;
    padding: 5px 11px;
    border-radius: var(--radius-md);
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-hover);
  }

  /* Right cluster */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (min-width: 640px) {
    .nav-right { margin-left: 0; }
  }

  /* Theme toggle */
  .nav-theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-md);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-tertiary);
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-theme-btn:hover {
    color: var(--color-text);
    background: var(--color-bg-hover);
  }

  /* Sun shown in dark mode, moon in light mode */
  .icon-moon { display: none; }
  :global([data-theme="light"]) .icon-sun  { display: none; }
  :global([data-theme="light"]) .icon-moon { display: block; }

  /* Mobile */
  .nav-mobile { position: relative; }

  .nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    list-style: none;
    padding: 8px;
    border-radius: var(--radius-md);
    transition: background 0.15s ease;
  }

  .nav-hamburger::-webkit-details-marker { display: none; }
  .nav-hamburger:hover { background: var(--color-bg-hover); }

  .hamburger-bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text-secondary);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  details[open] .hamburger-bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  details[open] .hamburger-bar:nth-child(2) { opacity: 0; }
  details[open] .hamburger-bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .nav-mobile-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 8px;
    min-width: 160px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    z-index: 50;
  }

  .nav-mobile-dropdown ul { list-style: none; }

  .nav-mobile-link {
    display: block;
    padding: 9px 14px;
    font-size: 14px;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-mobile-link:hover {
    background: var(--color-bg-hover);
    color: var(--color-text);
  }
</style>
