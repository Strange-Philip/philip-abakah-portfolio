---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import SectionDivider from './SectionDivider.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
  showAll?: boolean;
}

const { projects, showAll = false } = Astro.props;
const display = showAll ? projects : projects.filter(p => p.data.featured).slice(0, 3);
---

<section id="work" class="work-section" aria-label="Work and projects">
  <div class="container">
    {!showAll && <SectionDivider label="Works" href="/works" />}

    <div class="projects-grid">
      {display.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>

<style>
  .work-section {
    padding-bottom: 64px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
