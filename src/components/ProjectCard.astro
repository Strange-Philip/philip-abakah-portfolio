---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, tagline, image, imageAlt, status, year } = project.data;

const statusLabel: Record<string, string> = {
  live: 'Live',
  'in-progress': 'In Progress',
  research: 'Research',
  archived: 'Archived',
};
---

<article class="project-card">
  <a href={`/projects/${project.slug}`} class="card-link" aria-label={`View ${title} project`}>
    <div class="card-image-wrap">
      {image ? (
        <img
          src={image}
          alt={imageAlt || title}
          width="400"
          height="300"
          loading="lazy"
          class="card-image"
        />
      ) : (
        <div class="card-placeholder">
          <span class="placeholder-text">{title}</span>
        </div>
      )}
    </div>

    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      <div class="card-meta">
        {status && <span class={`card-status status-${status}`}>{statusLabel[status] ?? status}</span>}
        <span class="card-year">{year}</span>
      </div>
      <p class="card-tagline">{tagline}</p>
    </div>
  </a>
</article>

<style>
  .project-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  /* Image */
  .card-image-wrap {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-soft);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .project-card:hover .card-image {
    transform: scale(1.03);
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-bg-card), var(--color-bg-secondary));
  }

  .placeholder-text {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text-mute);
  }

  /* Body */
  .card-body {
    padding: 14px 2px 4px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .card-status {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: var(--radius-sm);
  }

  .status-live        { background: rgba(74,222,128,0.12); color: #4ade80; }
  .status-in-progress { background: rgba(96,165,250,0.12); color: #60a5fa; }
  .status-research    { background: rgba(251,191,36,0.10); color: #fbbf24; }
  .status-archived    { background: rgba(113,113,122,0.15); color: #71717a; }

  .card-year {
    font-size: 10px;
    font-weight: 500;
    color: var(--color-text-mute);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-tagline {
    font-size: 13px;
    color: var(--color-text-tertiary);
    line-height: 1.5;
  }
</style>
