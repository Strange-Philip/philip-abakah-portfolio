---
import ExperienceItem from './ExperienceItem.astro';

const experiences = [
  {
    role: 'Software Engineer',
    org: 'Envision Technologies B.V.',
    orgUrl: 'https://www.letsenvision.com/',
    period: 'Oct 2024 — Mar 2026',
    bullets: [
      'Developed accessible-first software for the blind and low-vision community, leveraging expertise in optometry and assistive technology',
      'Collaborated remotely with a high-performing team to enhance usability, AI-driven accessibility features, and screen reader compatibility',
      'Contributed to improving text recognition, navigation assistance, and real-time AI feedback systems',
    ],
  },
  {
    role: 'Mobile Developer (Part-time)',
    org: 'TripOclock',
    orgUrl: 'https://tripoclock.com/',
    period: 'Feb 2023 — Mar 2026',
    bullets: [
      'Built high-performance mobile apps for the African travel and tourism industry, ensuring cross-platform accessibility',
      'Implemented GraphQL APIs, AI-driven recommendations, multi-language support, and seamless payment integrations',
      'Accelerated deployment cycles with CI/CD pipelines (Codemagic, TestFlight), enabling fast feedback integration',
    ],
  },
  {
    role: 'Flutter Team Lead',
    org: 'Slightly Techie Community',
    orgUrl: 'https://www.slightlytechie.com/',
    period: 'Aug 2023 — Dec 2024',
    bullets: [
      'Led development of an e-commerce mobile app with an in-house points-based reward system',
      'Managed and mentored junior Flutter developers to improve code quality and efficiency',
      'Architected scalable microservices and integrated REST APIs for smooth transaction handling',
    ],
  },
  {
    role: 'Mobile Developer',
    org: 'Night Market',
    orgUrl: 'https://www.nightmarketgh.com/',
    period: 'Aug 2023 — Dec 2023',
    bullets: [
      'Enhanced food ordering and delivery mobile apps for the University of Ghana campus',
      'Developed responsive, scalable Flutter applications for multiple screen sizes, ensuring seamless UX across devices',
    ],
  },
  {
    role: 'Mobile Developer',
    org: 'Insurerity Digital',
    orgUrl: 'https://insurerity.com/',
    period: 'Feb 2021 — Dec 2022',
    bullets: [
      'Developed mobile and web-based insurance registration, purchase, and renewal platforms using Flutter',
      'Collaborated with backend teams using Django and Node.js to build robust REST APIs',
      'Designed Figma prototypes and UI components, improving user engagement; optimized app performance, reducing load times',
    ],
  },
  {
    role: 'Personal Projects',
    org: 'GitHub / Pub.Dev',
    orgUrl: 'https://github.com/Strange-Philip',
    period: 'Aug 2019 — Present',
    bullets: [
      'EyeDx AI — AI-powered eye disease diagnosis app using computer vision and deep learning',
      'Safe Step — assistive navigation system for the visually impaired using depth perception and CV',
      'IRIS — open-source Flutter package for ocular data visualization',
    ],
  },
];
---

<section id="experience" class="section experience-section" aria-label="Experience">
  <div class="container">
    <p class="section-label">💼 Experience</p>
    <h2 class="section-title">Where I've Worked</h2>

    <div class="experience-list">
      {experiences.map((exp, i) => (
        <ExperienceItem
          role={exp.role}
          org={exp.org}
          orgUrl={exp.orgUrl}
          period={exp.period}
          bullets={exp.bullets}
          isLast={i === experiences.length - 1}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .experience-section {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border-soft);
    border-bottom: 1px solid var(--color-border-soft);
  }

  .experience-list { max-width: 680px; }
</style>
