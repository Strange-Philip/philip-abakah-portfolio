---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionDivider from '../components/SectionDivider.astro';
import Footer from '../components/Footer.astro';

const stack = [
  { emoji: '🐦', name: 'Flutter' },
  { emoji: '🎯', name: 'Dart' },
  { emoji: '🐍', name: 'Python' },
  { emoji: '🧠', name: 'TensorFlow' },
  { emoji: '🖐️', name: 'MediaPipe' },
  { emoji: '⚡', name: 'FastAPI' },
  { emoji: '🔥', name: 'Firebase' },
  { emoji: '⚛️', name: 'React' },
  { emoji: '📘', name: 'TypeScript' },
  { emoji: '🌐', name: 'JavaScript' },
  { emoji: '🤖', name: 'Gemini API' },
  { emoji: '💎', name: 'Figma' },
  { emoji: '🧑‍💻', name: 'VS Code' },
  { emoji: '🐙', name: 'Git' },
];

const timeline = [
  {
    org: 'Envision Technologies B.V.',
    orgUrl: 'https://www.letsenvision.com/',
    role: 'Software Engineer · Remote',
    period: 'Oct 2024 → Mar 2026',
    active: false,
  },
  {
    org: 'TripOclock',
    orgUrl: 'https://tripoclock.com/',
    role: 'Mobile Developer · Part-time',
    period: 'Feb 2023 → Mar 2026',
    active: false,
  },
  {
    org: 'Slightly Techie Community',
    orgUrl: 'https://www.slightlytechie.com/',
    role: 'Flutter Team Lead',
    period: 'Aug 2023 → Dec 2024',
    active: false,
  },
  {
    org: 'Night Market',
    orgUrl: 'https://www.nightmarketgh.com/',
    role: 'Mobile Developer',
    period: 'Aug 2023 → Dec 2023',
    active: false,
  },
  {
    org: 'Insurerity Digital',
    orgUrl: 'https://insurerity.com/',
    role: 'Mobile Developer',
    period: 'Feb 2021 → Dec 2022',
    active: false,
  },
];
---

<BaseLayout title="About — Philip Abakah" description="Everything you need to know about me, in one place.">
  <Nav />
  <main>
    <div class="container">
      <PageHeader
        emoji="😎"
        title="About Me"
        subtitle="Everything you need to know about me, in one place"
      />
    </div>

    <!-- Bio -->
    <section class="container about-bio">
      <p>
        Hi 👋, Nice to meet you!
      </p>
      <p>
        I'm <strong>Philip Abakah</strong> — AI Engineer, Optometrist, and builder of real-world systems.
      </p>
      <p>
        I didn't come into this from computer science in the traditional way.
        I started early — building mobile applications in high school, long before I formally stepped into AI.
        That foundation in software engineering shaped how I think about building systems: practical,
        user-focused, and designed to actually be used.
      </p>
      <p>
        I later studied optometry 👨🏾‍⚕️ and vision science — perception, how people interact with the world —
        and somewhere along the way, I started asking a different question:
      </p>
      <blockquote class="bio-quote">
        What if we could build systems that don't just see… but actually <em>help people navigate reality</em>?
      </blockquote>
      <p>
        So I kept building, just in a different direction.
      </p>

      <h3 class="bio-heading">The Work</h3>
      <p>
        My work sits at the intersection of <strong>AI, healthcare, and accessibility</strong> — not as ideas,
        but as systems that run in the real world.
      </p>
      <p>
        One of the most defining projects I've built is <strong>Safe Step</strong>, my final year thesis —
        an AI-powered navigation system for visually impaired users, built around a real-time computer vision
        pipeline using YOLOv8. But the model was never the point. The real challenge was translating perception
        into action — turning noisy visual data into simple, usable guidance. Under simulated blindness,
        users went from <strong>0% task completion to 100%</strong> with the system.
      </p>
      <p>
        I've also built <strong>EyeDxAi</strong>, an AI-assisted diagnostic tool that combines image understanding
        with structured reasoning to suggest possible eye conditions and next steps — pushing me to think about
        how models can support real decision-making, not just predictions.
      </p>

      <h3 class="bio-heading">The Turning Point</h3>
      <p>
        Joining <a href="https://www.letsenvision.com/" target="_blank" rel="noopener noreferrer" class="body-link">Envision Technologies</a>
        late 2024 changed everything. Working on systems used by over <strong>100,000 blind and low vision users</strong>
        shifted how I think about building software. It wasn't about prototypes anymore. It was about reliability,
        usability, and designing systems that people depend on.
      </p>
      <p>
        It was the first time I saw something I worked on exist outside of me — in the hands of real users,
        in real environments, solving real problems.
      </p>
      <p>
        Outside of my core work, I enjoy following Formula One 🏎️ and occasionally exploring telemetry data
        to build small models. I also enjoy illustration, painting &amp; cooking.
        See what I'm doing <a href="/now" class="body-link body-link--internal">now</a>.
      </p>

      <div class="about-ctas">
        <a href="mailto:philipabakahmensah@gmail.com" class="btn btn-ghost about-btn">✉️ Say hello!</a>
        <a href="https://www.linkedin.com/in/philip-abakah-od-22a45a206/" target="_blank" rel="noopener noreferrer" class="btn btn-ghost about-btn">💼 LinkedIn</a>
      </div>
    </section>

    <!-- Software Stack -->
    <section class="container about-section">
      <SectionDivider label="Software Stack" />
      <div class="stack-grid">
        {stack.map((tool) => (
          <span class="stack-chip">
            <span class="chip-emoji">{tool.emoji}</span>
            {tool.name}
          </span>
        ))}
      </div>
    </section>

    <!-- Timeline -->
    <section class="container about-section">
      <SectionDivider label="Timeline" />
      <div class="timeline">
        {timeline.map((item) => (
          <div class="timeline-item">
            <span class={`timeline-dot ${item.active ? 'dot-active' : 'dot-done'}`} aria-hidden="true"></span>
            <div class="timeline-content">
              <p class="timeline-org">
                {item.orgUrl ? (
                  <a href={item.orgUrl} target="_blank" rel="noopener noreferrer" class="org-link">
                    {item.org} <span class="external-arrow">↗</span>
                  </a>
                ) : (
                  item.org
                )}
              </p>
              <p class="timeline-role">{item.role}</p>
              <span class="timeline-period">{item.period}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Research -->
    <section class="container about-section">
      <SectionDivider label="Research" />
      <div class="pub-card">
        <span class="pub-icon">📄</span>
        <div>
          <a
            href="https://gricghana.org/automating-glaucoma-diagnosis-using-artificial-intelligence/"
            target="_blank"
            rel="noopener noreferrer"
            class="pub-title"
          >
            Automating glaucoma diagnosis using artificial intelligence
          </a>
          <div class="pub-meta">
            <span class="pub-venue">Ghana Research & Industry Collaborative</span>
            <span class="pub-year-badge">2024</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section class="container about-section">
      <SectionDivider label="Awards" />
      <ul class="list-rows">
        <li>
          <span class="row-primary">🏆 Caraham Ophthalmics Prize for Innovation</span>
          <span class="row-secondary">2025</span>
        </li>
        <li>
          <span class="row-primary">⭐ Most Promising Student — OSAG UCC</span>
          <span class="row-secondary">2025</span>
        </li>
        <li>
          <span class="row-primary">🎓 GNPC Scholar</span>
          <span class="row-secondary">2020–2023</span>
        </li>
      </ul>
    </section>

    <!-- Certifications -->
    <section class="container about-section">
      <SectionDivider label="Certifications" />
      <ul class="list-rows">
        <li>
          <span class="row-primary">📊 IBM Data Fundamentals</span>
          <span class="row-secondary">2025</span>
        </li>
        <li>
          <span class="row-primary">🤖 AI Career Essentials — ALX Africa</span>
          <span class="row-secondary">2024</span>
        </li>
        <li>
          <span class="row-primary">🐍 Python & R Workshop — AIMS Rwanda</span>
          <span class="row-secondary">2025</span>
        </li>
        <li>
          <span class="row-primary">🐦 Flutter Development — Simplilearn</span>
          <span class="row-secondary">2022</span>
        </li>
      </ul>
    </section>

    <!-- Leadership -->
    <section class="container about-section about-section--last">
      <SectionDivider label="Leadership" />
      <ul class="list-rows">
        <li>
          <span class="row-primary">📱 Mobile Dev Team Lead</span>
          <span class="row-secondary">Slightly Techie Network</span>
        </li>
        <li>
          <span class="row-primary">🎓 Flutter Instructor</span>
          <span class="row-secondary">Google Dev Club, UCC</span>
        </li>
        <li>
          <span class="row-primary">🔬 Exhibition Team</span>
          <span class="row-secondary">Women in Vision Ghana</span>
        </li>
      </ul>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Bio */
  .about-bio {
    max-width: 640px;
    padding-bottom: 48px;
  }

  .about-bio p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .about-bio strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .bio-quote {
    border-left: 2px solid var(--color-accent);
    padding-left: 18px;
    margin-block: 20px;
    font-size: 16px;
    font-style: normal;
    color: var(--color-text);
    line-height: 1.7;
  }

  .bio-quote em {
    font-style: italic;
  }

  .bio-heading {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 32px;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  .about-ctas {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .about-btn {
    padding: 8px 18px;
    font-size: 13px;
    height: 38px;
    border-radius: var(--radius-md);
  }

  /* Sections */
  .about-section {
    padding-bottom: 48px;
  }

  .about-section--last {
    padding-bottom: 80px;
  }

  /* Stack */
  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .stack-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-soft);
    font-size: 13px;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .chip-emoji {
    font-size: 14px;
    line-height: 1;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 24px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 28px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -24px;
    top: 5px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid;
  }

  .dot-active {
    border-color: #60a5fa;
    background: #60a5fa;
  }

  .dot-done {
    border-color: #4ade80;
    background: #4ade80;
  }

  .timeline-org {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 2px;
  }

  .org-link {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .org-link:hover {
    color: var(--color-text-secondary);
  }

  .external-arrow {
    font-size: 12px;
    opacity: 0.5;
  }

  .timeline-role {
    font-size: 13px;
    color: var(--color-text-secondary);
    margin-bottom: 6px;
  }

  .timeline-period {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-mute);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-soft);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
  }

  /* Research publication card */
  .pub-card {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 16px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
  }

  .pub-icon {
    font-size: 20px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pub-title {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.45;
    margin-bottom: 8px;
    transition: color 0.15s ease;
  }

  .pub-title:hover {
    color: var(--color-accent);
  }

  .pub-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }

  .pub-venue {
    font-size: 12px;
    color: var(--color-text-tertiary);
  }

  .pub-year-badge {
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-mute);
    background: var(--color-bg-card);
    padding: 2px 7px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border-soft);
  }

  /* List rows — awards, certifications, leadership */
  .list-rows {
    list-style: none;
  }

  .list-rows li {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    padding-block: 10px;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .list-rows li:last-child {
    border-bottom: none;
  }

  .row-primary {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .row-secondary {
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-mute);
    white-space: nowrap;
  }
</style>
