---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';

const checkSvg = `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="#34d399"/><path d="M5 9.5 L7.5 12 L13 6.5" stroke="#09090b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const hourglassSvg = `<svg class="il-hourglass" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 2h10M3 14h10M4 2v2.5C4 7 8 8 8 8S4 9 4 11.5V14M12 2v2.5C12 7 8 8 8 8s4 1 4 3.5V14" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<BaseLayout
  title="The Impossible List — Philip Abakah"
  description="A living list of things I'm working toward — across computer vision, vision science, and real-world systems."
>
  <Nav />
  <main>
    <div class="container">
      <PageHeader
        emoji="🏔️"
        title="The Impossible List"
        subtitle="A living list of things I'm working toward — across computer vision, vision science, and real-world systems."
      />

      <div class="il-intro">
        <p>I will be updating this list regularly. If you are someone who can help me make one of these a reality, please <a href="mailto:philipabakahmensah@gmail.com" class="body-link">get in touch</a>.</p>
        <p class="il-legend">
          <span class="legend-item legend-done"><Fragment set:html={checkSvg} /> done</span>
          <span class="legend-sep">·</span>
          <span class="legend-item legend-progress"><Fragment set:html={hourglassSvg} /> in progress</span>
          <span class="legend-sep">·</span>
          <span class="legend-item legend-planned"><span class="legend-circle"></span> planned</span>
        </p>
        <p class="il-updated">Last updated on <strong>April 4, 2026</strong></p>
      </div>

      <div class="il-body">

        <!-- Impact Goals -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🧠</span> Impact Goals</h2>
          <ul class="il-list">
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Build systems that improve how humans perceive and interact with the world <span class="il-note">current focus: vision + AI systems</span>
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Help someone who is visually impaired navigate independently using <a href="/projects/safe-step" class="body-link body-link--internal">Safe Step</a> — in the real world <span class="il-note">prototype stage</span>
            </li>
            <li class="il-item">Build technology used by 1,000,000+ users across healthcare, mobility, and perception</li>
            <li class="il-item">Contribute to global accessibility AND medical AI systems</li>
            <li class="il-item">Build tools that assist clinicians, not just patients</li>
          </ul>
        </section>

        <!-- Research Goals -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🔬</span> Research Goals</h2>
          <ul class="il-list">
            <li class="il-item">Publish research spanning Computer Vision × AI/ML × Ophthalmology</li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Work with ophthalmic datasets (fundus, OCT, visual fields) <span class="il-note">currently exploring OCT + fundus data</span>
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Build models beyond classification → representation learning + multimodal systems <span class="il-note">experimenting with CV pipelines</span>
            </li>
            <li class="il-item">Present at <a href="https://www.arvo.org" target="_blank" rel="noopener noreferrer" class="body-link">ARVO</a> (Association for Research in Vision and Ophthalmology)</li>
            <li class="il-item">Contribute to or collaborate with <a href="https://www.nei.nih.gov" target="_blank" rel="noopener noreferrer" class="body-link">NEI</a> (National Eye Institute)-level research</li>
            <li class="il-item">Earn <a href="https://www.aao.org" target="_blank" rel="noopener noreferrer" class="body-link">FAAO</a> (Fellow of the American Academy of Optometry)</li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Reproduce and improve a state-of-the-art computer vision paper <span class="il-note">paper reading + implementation stage</span>
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Open-source systems that others can build on <span class="il-note">Safe Step + related work planned</span>
            </li>
          </ul>
        </section>

        <!-- Engineering Goals -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🧑🏾‍💻</span> Engineering Goals</h2>
          <ul class="il-list">
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Build real-world computer vision systems (not just models in notebooks) <span class="il-note"><a href="/projects/safe-step" class="body-link body-link--internal">Safe Step</a>, <a href="/projects/eyedxai" class="body-link body-link--internal">EyeDxAI</a></span>
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Develop systems across medical imaging, real-world environments, and multimodal inputs <span class="il-note">currently combining navigation + perception models</span>
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Become deeply strong in Computer Vision + AI/ML (theory + systems) <span class="il-note">actively learning + building</span>
            </li>
            <li class="il-item">Build systems that generalize across datasets and environments</li>
          </ul>
        </section>

        <!-- Career Goals -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🌍</span> Career Goals</h2>
          <ul class="il-list">
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Get into a top graduate program (Vision Science / AI / Biomedical Engineering) <span class="il-note">building portfolio + research direction</span>
            </li>
            <li class="il-item">Become a Vision Scientist Engineer at Apple</li>
            <li class="il-item">Work at the intersection of perception, hardware, and intelligence</li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Build systems that reach global, real-world scale <span class="il-note">starting with Safe Step</span>
            </li>
          </ul>
        </section>

        <!-- Personal Growth -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🧠</span> Personal Growth</h2>
          <ul class="il-list">
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Read deeply across AI, neuroscience, perception, and philosophy
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Become extremely strong at first-principles thinking
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Communicate complex ideas simply and clearly
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Document ideas, experiments, and learning publicly <span class="il-note">in progress</span>
            </li>
          </ul>
        </section>

        <!-- Life Experiences -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">✈️</span> Life Experiences</h2>
          <ul class="il-list">
            <li class="il-item">Travel outside Ghana for research, collaboration, or conferences</li>
            <li class="il-item">Attend and present at a global research conference</li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Work with teams solving high-impact scientific problems <span class="il-note">remote collaboration experience</span>
            </li>
          </ul>
        </section>

        <!-- Experiments -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🧪</span> Experiments</h2>
          <ul class="il-list">
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Build and ship a project in 7 days (end-to-end) <span class="il-note">ongoing challenge</span>
            </li>
            <li class="il-item">Ship something publicly every month for 6 months</li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Explore one new research idea regularly <span class="il-note">active exploration</span>
            </li>
            <li class="il-item il-item--progress">
              <span class="il-icon" aria-hidden="true"><Fragment set:html={hourglassSvg} /></span>
              Test and validate 10+ ideas within 30 days <span class="il-note">iteration mindset</span>
            </li>
          </ul>
        </section>

        <!-- Wild Ideas -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">⚡</span> Wild Ideas</h2>
          <ul class="il-list">
            <li class="il-item">Build a generalist vision model for ophthalmology (multi-task, multimodal)</li>
            <li class="il-item">Create systems that infer unseen structure/function from images</li>
            <li class="il-item">Build tools that augment human perception beyond biological limits</li>
            <li class="il-item">Contribute to systems that move toward a digital understanding of vision</li>
          </ul>
        </section>

        <!-- Bucket List -->
        <section class="il-section">
          <h2 class="il-heading"><span class="il-emoji">🌱</span> Bucket List</h2>
          <ul class="il-list">
            <li class="il-item">Attend an Apple Event (WWDC or product launch)</li>
            <li class="il-item">Visit New York City</li>
            <li class="il-item">Visit Silicon Valley</li>
            <li class="il-item">Visit Apple Park</li>
            <li class="il-item">Travel outside Ghana for the first time</li>
          </ul>
        </section>

        <!-- Done -->
        <section class="il-section il-section--done">
          <h2 class="il-heading"><span class="il-emoji">🏁</span> Done</h2>
          <ul class="il-list">
            <li class="il-item il-item--done">
              <span class="il-check" aria-hidden="true"><Fragment set:html={checkSvg} /></span>
              Worked at a global AI company building accessibility tools — <a href="https://www.letsenvision.com/" target="_blank" rel="noopener noreferrer" class="body-link">Envision Technologies</a>
            </li>
            <li class="il-item il-item--done">
              <span class="il-check" aria-hidden="true"><Fragment set:html={checkSvg} /></span>
              Built real-world AI systems — <a href="/projects/safe-step" class="body-link body-link--internal">Safe Step</a>, <a href="/projects/eyedxai" class="body-link body-link--internal">EyeDxAI</a>
            </li>
            <li class="il-item il-item--done">
              <span class="il-check" aria-hidden="true"><Fragment set:html={checkSvg} /></span>
              Combined optometry + machine learning into actual products
            </li>
          </ul>
        </section>

      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  main { min-height: calc(100vh - 80px); }

  .il-intro {
    text-align: left;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .il-intro > p:first-child {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .il-legend {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-mute);
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .legend-circle {
    display: inline-block;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
  }

  .legend-sep { color: var(--color-border); }

  .il-updated {
    font-size: 13px;
    color: var(--color-text-mute);
  }

  .il-updated strong {
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  /* Body */
  .il-body {
    max-width: 600px;
    margin-inline: auto;
    padding-bottom: 96px;
  }

  .il-section {
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 36px;
    margin-bottom: 36px;
  }

  .il-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
  }

  .il-heading {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .il-emoji {
    font-size: 15px;
    letter-spacing: 0;
    text-transform: none;
  }

  .il-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Base item — planned (empty circle) */
  .il-item {
    position: relative;
    padding-left: 28px;
    font-size: 15px;
    color: var(--color-text);
    line-height: 1.65;
    cursor: default;
  }

  .il-item:not(.il-item--done):not(.il-item--progress)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .il-item:not(.il-item--done):not(.il-item--progress):hover::before {
    border-color: var(--color-accent);
    transform: scale(1.15);
  }

  /* In-progress */
  .il-item--progress {
    color: var(--color-text-secondary);
  }

  .il-icon {
    position: absolute;
    left: 0;
    top: 3px;
    display: flex;
    align-items: center;
    transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.27, 1.55);
  }

  .il-item--progress:hover .il-icon {
    transform: rotate(180deg);
  }

  /* Note (parenthetical) */
  .il-note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    margin-left: 4px;
  }

  .il-note::before { content: '('; }
  .il-note::after  { content: ')'; }

  /* Done — checkmark bounce on hover */
  .il-item--done {
    color: var(--color-text-secondary);
  }

  .il-check {
    position: absolute;
    left: 0;
    top: 2px;
    display: flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .il-item--done:hover .il-check {
    transform: scale(1.2);
  }

  .il-section--done .il-heading {
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .il-hourglass { animation: none; }
  }
</style>
